# VITE_GEMINI_API_KEY: Required for Gemini AI API calls in the Vite frontend.
# Set this to your Gemini API key from Google AI Studio.
VITE_GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# JWT_SECRET: Used for session authentication.
JWT_SECRET="your_super_secret_key_here_change_in_production"

# DATABASE_PATH: Optional absolute or relative path for the SQLite database file.
# Use a mounted persistent disk path on hosting platforms, for example:
# DATABASE_PATH="/var/data/campus.db"
DATABASE_PATH="./campus.db"
