# VITE_GEMINI_API_KEY: Required for Gemini AI API calls in the Vite frontend.
# Set this to your Gemini API key from Google AI Studio.
VITE_GEMINI_API_KEY="API KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# FRONTEND_ORIGIN: Allowed browser origin for a separately hosted frontend.
# Set this when the UI runs on GitHub Pages or another domain and the Node API runs elsewhere.
FRONTEND_ORIGIN="http://localhost:5173"

# VITE_API_BASE_URL: Optional absolute backend URL for static frontend deployments.
# Example for GitHub Pages: "https://your-api-host.example.com"
VITE_API_BASE_URL=""

# VITE_BASE_PATH: Optional subpath for static hosts such as GitHub Pages.
# Example: "/mbu-planning/"
VITE_BASE_PATH="/"

# JWT_SECRET: Used for session authentication.
JWT_SECRET="Secret Key"

# DATABASE_PATH: Optional absolute or relative path for the SQLite database file.
# Use a mounted persistent disk path on hosting platforms, for example:
# DATABASE_PATH="/var/data/campus.db"
DATABASE_PATH="./campus.db"
